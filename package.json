{
  "name": "bugside",
  "version": "0.1.3",
  "description": "Next.js · Supabase · Vercel errors in one terminal pane",
  "type": "module",
  "bin": {
    "bugside": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
