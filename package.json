    "chalk": "^5.3.0",
    "dotenv": "^16.0.0",
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/http-proxy": "^1.17.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
